# Виртуальное окружение
.venv/
venv/
env/

# Секреты OAuth / Google: содержимое папки не в Git (см. credentials/README.md)
credentials/*
!credentials/.gitkeep
!credentials/README.md

# Секреты вне credentials/ (на случай случайного сохранения)
**/client_secret*.json
**/token.json
*.pickle

# Состояние PicklePersistence (PTB). По умолчанию бот кладёт state.pickle в ./state/,
# путь можно переопределить через BOT_PERSISTENCE_FILE в .env.
state/
magistrcheckbot_state.pickle

# Локальные переменные окружения
.env
.env.local

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE
.idea/
.vscode/

# Личные черновики рядом с документацией (не коммитить)
docs/private/

# key for Google Cloud API
key/
keys/