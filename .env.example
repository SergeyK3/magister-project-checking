# Telegram bot @magistrcheckbot — пример переменных окружения.
# Скопируйте в .env (не коммитится, см. .gitignore) и заполните своими значениями.

# Токен от @BotFather для @magistrcheckbot
TELEGRAM_BOT_TOKEN=

# ID Google Sheets, в которую бот пишет регистрацию.
# Возьмите из URL таблицы: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
# В той же книге должны быть листы «Администраторы» и «научрук» (колонки как у
# админов: fio, telegram_id, active) — иначе сценарии /start с ролью
# «админ»/«научрук» и привязка по ФИО не сработают.
SPREADSHEET_ID=

# Имя листа в Google Sheets (по умолчанию: Регистрация)
WORKSHEET_NAME=Регистрация

# Путь к JSON-ключу Google Service Account (положите файл в credentials/, он в .gitignore).
# Сервисному аккаунту нужно дать права редактора на указанную таблицу:
# поделиться SPREADSHEET_ID на email из этого JSON-ключа (поле "client_email").
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service_account.json

# Альтернатива пути — содержимое JSON-ключа целиком (удобно для Cursor Cloud Agent
# Secrets, GitHub Actions и т.п., где файл положить нельзя). Если задано —
# имеет приоритет над GOOGLE_SERVICE_ACCOUNT_JSON; будет записано во временный
# файл с правами 600.
# GOOGLE_SERVICE_ACCOUNT_JSON_CONTENT={"type":"service_account", ...}

# Папка-буфер на Google Drive: бот копирует туда .docx-отчёты с конверсией
# в Google Doc (Docs API не умеет читать .docx напрямую) и сразу удаляет
# копию. Требуется, если магистранты загружают отчёты как .docx.
# Принимается URL (…/drive/folders/<ID>) или чистый ID.
#
# ВАЖНО: папка ДОЛЖНА лежать в Shared Drive, а Service Account из
# GOOGLE_SERVICE_ACCOUNT_JSON должен быть добавлен в этот Shared Drive
# как Content Manager (writer/fileOrganizer/organizer). Если папка в
# обычном My Drive, копирование упадёт с HTTP 403 storageQuotaExceeded
# (у SA без Workspace квота = 0).
#
# Имена переменных в порядке приоритета (читается первая непустая):
#   GOOGLE_DRIVE_BUFFER_FOLDER_URL
#   GOOGLE_DRIVE_BUFFER_FOLDER_ID
#   DOCX_CONVERSION_FOLDER_URL  (legacy)
#   DOCX_CONVERSION_FOLDER_ID   (legacy)
GOOGLE_DRIVE_BUFFER_FOLDER_URL=

# Уровень логирования: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Путь к файлу PicklePersistence — PTB сохраняет туда состояние диалогов
# (user_data, chat_data, текущий шаг ConversationHandler). Благодаря этому
# после перезапуска бота магистранты продолжают регистрацию с того же шага.
# По умолчанию: state/magistrcheckbot_state.pickle (относительно каталога,
# откуда запускается бот — обычно это корень репозитория). Файл и каталог
# ``state/`` уже внесены в .gitignore, так что в Git они не попадут.
# BOT_PERSISTENCE_FILE=state/magistrcheckbot_state.pickle

# Файл лога для headless / Task Scheduler (Python FileHandler, JSON-строки).
# См. scripts/bot_run_headless.ps1 — без этого stderr через PowerShell 5.x может
# ронять процесс при $ErrorActionPreference=Stop.
# BOT_LOG_FILE=state/logs/bot.log

# Через запятую: chat_id получателей алертов при необработанной ошибке в хендлере.
# Узнать свой user_id: /start у бота (или @userinfobot). Для группы — отрицательный id.
# Пусто — только запись в лог, без сообщений в Telegram.
# BOT_ALERT_CHAT_IDS=

# Google Drive: JSON project snapshot (docs/contract_project_snapshot.md) — после
# --apply / «Перепроверить» и при «Карточка проекта». Ровно одна папка:
# PROJECT_CARD_OUTPUT_FOLDER_URL=https://drive.google.com/drive/folders/...
# Несколько папок (копия JSON в каждую), через запятую без пробелов в URL или в кавычках не нужны:
# PROJECT_SNAPSHOT_OUTPUT_FOLDER_URLS=https://.../folders/ID1,https://.../folders/ID2
# Если задана PROJECT_SNAPSHOT_OUTPUT_FOLDER_URLS, она полностью задаёт список; PROJECT_CARD… не подмешивается.
# Service account: Content manager на каждую папку. Пусто — в Drive снимки не пишутся.
# PROJECT_CARD_OUTPUT_FOLDER_URL=
# PROJECT_SNAPSHOT_OUTPUT_FOLDER_URLS=

# === Правила оформления магистерских проектов (Stage 4 compliance) ===
# Используются для подробного диагноза «найдено / нужно» в колонке
# «Соответствие оформлению» и в Telegram-отчёте магистранту. Все значения —
# дефолтные требования методички; перезапишите, если в вашем учебном плане
# нормативы другие. Если переменная не задана — берётся дефолт из кода
# (magister_checking/formatting_rules.py).
# FORMATTING_FONT_FAMILY=Times New Roman
# FORMATTING_FONT_SIZE_PT=14
# FORMATTING_LINE_SPACING=single
# FORMATTING_MARGIN_TOP_CM=2.0
# FORMATTING_MARGIN_BOTTOM_CM=1.0
# FORMATTING_MARGIN_LEFT_CM=3.0
# FORMATTING_MARGIN_RIGHT_CM=1.0
# Положение номера страницы: bottom-right / bottom-center / bottom-left /
# top-right / top-center / top-left
# FORMATTING_PAGE_NUMBERING_POSITION=bottom-right
# Доля символов/абзацев, ниже которой шрифт/кегль/интервал считаются
# несоответствующими (0.95 = строже 95%).
# FORMATTING_RATIO_THRESHOLD=0.95
# Допуск по полям в см (±). 0.2 см = 2 мм — типичная погрешность экспорта
# DOCX из Google Docs.
# FORMATTING_MARGIN_TOLERANCE_CM=0.2
